  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "comment",
          "punctuation.definition.comment"
        ],
        "settings": {
          "foreground": "#9198ae",
          "fontStyle": "italic"
        }
      },
      {
        "scope": [
          "keyword",
          "storage",
          "keyword.control",
          "punctuation.definition.keyword"
        ],
        "settings": {
          "foreground": "#273c82"
        }
      },
      {
        "scope": [
          "entity.name.function",
          "support.function",
          "meta.function-call"
        ],
        "settings": {
          "foreground": "#2354e6"
        }
      },
      {
        "scope": [
          "entity.name.type",
          "entity.name.class",
          "support.type"
        ],
        "settings": {
          "foreground": "#1a1d27",
          "fontStyle": "bold"
        }
      },
      {
        "scope": [
          "string",
          "constant.other.symbol"
        ],
        "settings": {
          "foreground": "#0b8a55"
        }
      },
      {
        "scope": [
          "constant.numeric",
          "constant.language"
        ],
        "settings": {
          "foreground": "#c47c00"
        }
      },
      {
        "scope": [
          "variable",
          "meta.definition.variable.name"
        ],
        "settings": {
          "foreground": "#1a1d27"
        }
      },
      {
        "scope": [
          "invalid",
          "invalid.illegal"
        ],
        "settings": {
          "foreground": "#d93a52",
          "fontStyle": "underline"
        }
      }
    ]
  },
  "editor.semanticTokenColorCustomizations": {
    "enabled": true,
    "rules": {
      "function": "#2354e6",
      "method": "#2354e6",
      "class": {
        "foreground": "#1a1d27",
        "bold": true
      },
      "type": "#273c82",
      "enumMember": "#c47c00",
      "property": "#545c73",
      "parameter": "#1a1d27",
      "variable.readonly": "#273c82",
      "comment": {
        "foreground": "#9198ae",
        "italic": true
      }
    }
  },
  "editor.fontFamily": "'JetBrains Mono', Menlo, Monaco, 'Courier New', monospace",
  "terminal.integrated.fontFamily": "'JetBrains Mono', Menlo, Monaco, 'Courier New', monospace",
    "workbench.colorTheme": "Default Light+",
    "workbench.preferredLightColorTheme": "Default Light+"
}
